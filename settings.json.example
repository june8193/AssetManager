{
  // 키움증권 REST API 서비스 URL
  "base_url": "https://api.kiwoom.com",
  
  // 키움증권 실시간 웹소켓(WSS) URL
  "ws_url": "wss://api.kiwoom.com:10000/api/dostk/websocket",

  // 증권사 계좌 정보 목록 (여러 계정 등록 가능)
  "accounts": [
    {
      "broker": "키움증권",                // 증권사 명칭
      "account": "5526-9093",             // 계좌 번호
      "app_key": "YOUR_APP_KEY",          // 발급받은 APP KEY
      "secret_key": "YOUR_SECRET_KEY"     // 발급받은 SECRET KEY
    }
  ],

  // 데이터베이스 자동 백업 설정
  "backup": {
    "interval_hours": 24,    // 백업 주기 (단위: 시간)
    "path": "./backups",     // 백업 파일이 저장될 상대/절대 경로
    "max_files": 7           // 보관할 최대 백업 파일 개수 (초과 시 오래된 파일부터 삭제)
  }
}
